-- SENSOR LOGIC (BACKGROUND)
-- ==========================================
if playerGui:FindFirstChild("EffortlessResizer") then
    playerGui.EffortlessResizer:Destroy()
end

local function getNearestSensor()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = char.HumanoidRootPart.Position
    
    local nearest = nil
    local minDist = math.huge
    
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name == "PrizeSensor" then
            local dist = (obj.Position - myPos).Magnitude
            if dist < minDist then
                minDist = dist
                nearest = obj
            end
        end
    end
    return nearest
end

local targetSensor = getNearestSensor()
if targetSensor then
    targetSensor.Size = automaticSensorSize
    targetSensor.Transparency = 1 
    targetSensor.CanCollide = false
end

