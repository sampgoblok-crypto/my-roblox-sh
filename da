local resetButton, resetText = createButton("ResetBtn", "RESET CHARACTER", blackColor, textColorLight)

-- ==========================================
-- INTERACTIONS & HOVER ANIMATIONS
-- ==========================================

-- DRAGGABLE LOGIC
local dragging, dragInput, dragStart, startPos

topBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

topBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

userInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- SMOOTH HOVER ANIMATIONS (PHYSICAL SQUEEZE)
local tweenInfoHover = TweenInfo.new(0.2, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
local tweenInfoClick = TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local function animateButton(button, baseBg, hoverBg, clickBg)
    local originalSize = UDim2.new(1, 0, 0, 42)
    local hoverSize = UDim2.new(1, -8, 0, 42) 
    local clickSize = UDim2.new(1, -12, 0, 40) 

    button.MouseEnter:Connect(function() 
        tweenService:Create(button, tweenInfoHover, {BackgroundColor3 = hoverBg, Size = hoverSize}):Play() 
    end)
    button.MouseLeave:Connect(function() 
        tweenService:Create(button, tweenInfoHover, {BackgroundColor3 = baseBg, Size = originalSize}):Play() 
    end)
    button.MouseButton1Down:Connect(function() 
        tweenService:Create(button, tweenInfoClick, {BackgroundColor3 = clickBg, Size = clickSize}):Play() 
    end)
    button.MouseButton1Up:Connect(function() 
        tweenService:Create(button, tweenInfoHover, {BackgroundColor3 = hoverBg, Size = hoverSize}):Play() 
    end)
end

animateButton(bringButton, whiteColor, Color3.fromRGB(210, 210, 210), Color3.fromRGB(160, 160, 160))
animateButton(resetButton, blackColor, Color3.fromRGB(35, 35, 40), Color3.fromRGB(55, 55, 60))

-- ==========================================
-- CORE FUNCTIONS
-- ==========================================
local function getClosestPrizeSensor(myPos)
    local target = nil
    local closestDist = math.huge
    local nearbyParts = workspace:GetPartBoundsInRadius(myPos, 50)
    
    for _, obj in ipairs(nearbyParts) do
        if obj.Name == "PrizeSensor" then
            local dist = (obj.Position - myPos).Magnitude
            if dist < closestDist then
                closestDist = dist
                target = obj
            end
        end
    end
    return target
end

-- BUTTON EVENTS
bringButton.MouseButton1Click:Connect(function()
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end

    local sensor = getClosestPrizeSensor(character.HumanoidRootPart.Position)
    if not sensor then 
        bringText.Text = "NO SENSOR NEARBY"
        task.wait(1.5)
        bringText.Text = "GET PRIZES"
        return 
    end

    local movedCount = 0
    local prizesInRadius = workspace:GetPartBoundsInRadius(sensor.Position, areaRadius)
    
    for _, obj in ipairs(prizesInRadius) do
        if obj.Name == "Prize" then
            obj.CanCollide = collisionEnabled
            obj.CFrame = sensor.CFrame
            movedCount = movedCount + 1
        end
    end

    if movedCount > 0 then
        bringText.Text = "PULLED (" .. movedCount .. ")"
        tweenService:Create(bringText, tweenInfoHover, {TextColor3 = Color3.fromRGB(120, 120, 120)}):Play()
        task.wait(1.5)
        bringText.Text = "GET PRIZES"
        tweenService:Create(bringText, tweenInfoHover, {TextColor3 = textColorDark}):Play()
    else
        bringText.Text = "NO PRIZES FOUND"
        task.wait(1.5)
        bringText.Text = "GET PRIZES"
    end
end)

resetButton.MouseButton1Click:Connect(function()
    local character = player.Character
    if character and character:FindFirstChild("Humanoid") then
        character.Humanoid.Health = 0
    end
end)
