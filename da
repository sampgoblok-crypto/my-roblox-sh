-- DRAGGABLE UI LOGIC
local dragging, dragInput, dragStart, startPos

mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

mainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

userInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)


local originalColor = bringButton.BackgroundColor3
local hoverColor = Color3.fromRGB(29, 78, 216) 
local clickColor = Color3.fromRGB(30, 58, 138) 

local originalSize = bringButton.Size
local originalPos = bringButton.Position
local clickSize = UDim2.new(originalSize.X.Scale, originalSize.X.Offset - 6, originalSize.Y.Scale, originalSize.Y.Offset - 4)
local clickPos = UDim2.new(originalPos.X.Scale, originalPos.X.Offset + 3, originalPos.Y.Scale, originalPos.Y.Offset + 2)

local tweenInfoFast = TweenInfo.new(0.06, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local tweenInfoReturn = TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
local tweenInfoHover = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

bringButton.MouseEnter:Connect(function() tweenService:Create(bringButton, tweenInfoHover, {BackgroundColor3 = hoverColor}):Play() end)
bringButton.MouseLeave:Connect(function() tweenService:Create(bringButton, tweenInfoHover, {BackgroundColor3 = originalColor}):Play() end)
bringButton.MouseButton1Down:Connect(function() tweenService:Create(bringButton, tweenInfoFast, {BackgroundColor3 = clickColor, Size = clickSize, Position = clickPos}):Play() end)
bringButton.MouseButton1Up:Connect(function() tweenService:Create(bringButton, tweenInfoReturn, {BackgroundColor3 = hoverColor, Size = originalSize, Position = originalPos}):Play() end)


local function getClosestPrizeSensor(myPos)
    local targetSensor = nil
    local closestDist = math.huge
    
    local nearbyParts = workspace:GetPartBoundsInRadius(myPos, 50)
    
    for _, obj in ipairs(nearbyParts) do
        if obj.Name == "PrizeSensor" then
            local dist = (obj.Position - myPos).Magnitude
            if dist < closestDist then
                closestDist = dist
                targetSensor = obj
            end
        end
    end
    return targetSensor
end


bringButton.MouseButton1Click:Connect(function()
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    local playerPosition = character.HumanoidRootPart.Position

    local sensor = getClosestPrizeSensor(playerPosition)
    if not sensor then 
        bringButton.Text = "No Sensor Nearby"
        task.wait(1.5)
        bringButton.Text = "Bring Prize"
        return 
    end

    local movedCount = 0

    local prizesInRadius = workspace:GetPartBoundsInRadius(sensor.Position, areaRadius)
    
    for _, obj in ipairs(prizesInRadius) do
        if obj.Name == "Prize" then
            obj.CanCollide = collisionEnabled
            obj.CFrame = sensor.CFrame
            movedCount = movedCount + 1
        end
    end

    if movedCount > 0 then
        bringButton.Text = "Success (" .. movedCount .. ")"
        local successTween = tweenService:Create(bringButton, tweenInfoHover, {BackgroundColor3 = Color3.fromRGB(22, 163, 74)}) 
        successTween:Play()
        task.wait(1.2)
        bringButton.Text = "Bring Prize"
        tweenService:Create(bringButton, tweenInfoHover, {BackgroundColor3 = originalColor}):Play()
    else
        bringButton.Text = "No Prizes Found"
        task.wait(1.2)
        bringButton.Text = "Bring Prize"
    end
end)
