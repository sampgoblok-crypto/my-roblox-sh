-- 7. Smart Respawn Helper Function
local function waitForRespawn()
    local player = Players.LocalPlayer
    local oldCharacter = player.Character
    
    ResetEvent:FireServer(true)
    
    while player.Character == oldCharacter do
        task.wait(0.05)
    end
    
    local newCharacter = player.Character or player.CharacterAdded:Wait()
    newCharacter:WaitForChild("HumanoidRootPart", 5)
    
    task.wait(0.1) 
end

-- 8. Coin Farm Logic (1-61 Instant Loop + Reset)
local isCoinFarm = false

CoinFarmButton.MouseButton1Click:Connect(function()
    isCoinFarm = not isCoinFarm 
    
    if isCoinFarm then
        CoinFarmButton.Text = "Coin Farm: ON"
        CoinFarmButton.BackgroundColor3 = Color3.fromRGB(0, 170, 100) 
        CoinFarmStroke.Color = Color3.fromRGB(0, 220, 130)
        
        task.spawn(function()
            while isCoinFarm do
                -- INSTANT FIRE: Removed task.wait() from this loop
                for i = 1, 61 do
                    if not isCoinFarm then break end 
                    CheckpointEvent:FireServer(i)
                end
                
                if isCoinFarm then
                    waitForRespawn()
                end
            end
        end)
    else
        CoinFarmButton.Text = "Coin Farm: OFF"
        CoinFarmButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40) 
        CoinFarmStroke.Color = Color3.fromRGB(80, 80, 80)
    end
end)

-- 9. Auto Win Logic (Checkpoint 61 Only + Reset)
local isAutoWin = false

AutoWinButton.MouseButton1Click:Connect(function()
    isAutoWin = not isAutoWin
    
    if isAutoWin then
        AutoWinButton.Text = "Auto Win: ON"
        AutoWinButton.BackgroundColor3 = Color3.fromRGB(0, 170, 100) 
        AutoWinStroke.Color = Color3.fromRGB(0, 220, 130)
        
        task.spawn(function()
            while isAutoWin do
                CheckpointEvent:FireServer(61)
                
                if isAutoWin then
                    waitForRespawn()
                end
            end
        end)
    else
        AutoWinButton.Text = "Auto Win: OFF"
        AutoWinButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40) 
        AutoWinStroke.Color = Color3.fromRGB(80, 80, 80)
    end
end)
